# Probe target — where `npm run probe -- --endpoint <id>` sends requests.
# Typically a running Privicore sandbox reachable from your machine.
PRIVICORE_API_URL=http://localhost:8009
PRIVICORE_WS_URL=ws://localhost:8083

# Credentials for the probe runs. Use a dedicated doc-writer profile so
# probe activity doesn't pollute real workloads.
PRIVICORE_USERNAME=
PRIVICORE_PASSWORD=

# URLs displayed in the rendered documentation site. Distinct from the
# probe URLs — the probe might talk to localhost while published docs
# point at a public sandbox. Substituted into markdown and OpenAPI
# descriptions as `{{apiUrl}}`, `{{wsUrl}}`, etc.
DOCS_API_URL=https://cab.example.com
DOCS_WS_URL=wss://cab.example.com:8083
DOCS_UPSTREAM_URL=https://upstream.example.com:8010
DOCS_DOWNSTREAM_URL=https://downstream.example.com:8011

# Apidog integration is dormant (see CLAUDE.md) — left here so the
# dormant `src/apidog/` module still compiles. Safe to leave empty.
APIDOG_TOKEN=
APIDOG_API_BASE=https://api.apidog.com
APIDOG_PROJECT_ID=
